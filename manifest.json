{
  "manifest_version": 3,
  "name": "✨ Highlight AI — Smart Text Assistant",
  "version": "1.0",
  "description": "Highlight any text for instant AI-powered actions: explain, simplify, translate, convert to notes, and more.",
  "permissions": [
    "activeTab",
    "storage",
    "contextMenus"
  ],
  "host_permissions": [
    "https://router.huggingface.co/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Highlight AI - Smart Text Assistant",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["panel.css"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "open-popup": {
      "suggested_key": {
        "default": "Alt+H",
        "mac": "Alt+H"
      },
      "description": "Open Highlight AI settings popup"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
